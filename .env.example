# ── Supabase ────────────────────────────────────────────────
# Supabaseプロジェクト作成後、Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（Edge Function/APIルートでのみ使用。クライアントに出さない）
SUPABASE_SERVICE_ROLE_KEY=

# ── connpass API v2 ─────────────────────────────────────────
# https://connpass.com/about/api/ から利用申請して取得
CONNPASS_API_KEY=

# ── X (Twitter) API v2 ──────────────────────────────────────
# https://developer.x.com/ でアプリ作成し、User認証トークンを取得
# ※ まずはオーナー1アカウント投稿用。将来はユーザーごとのOAuthに置き換え
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
